{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>Omochice/renovate-config:deno",
    ":semanticCommits"
  ],

  "gitAuthor": "github-actions[bot] 3051899+github-actions[bot]@users.noreply.github.com",

  "platformAutomerge": true,

  "packageRules": [
    {
      "description": "Disallow Major update to clickhouse and postgres",
      "matchPackageNames": [
        "docker.io/clickhouse/clickhouse-server",
        "docker.io/postgres"
      ],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },

    {
      "groupName": "github/workflows",
      "description": "Group all github actions into a single PR",
      "matchManagers": ["github-actions"],
      "automergeType": "pr",
      "automerge": true
    },

    {
      "groupName": "helm/kube-system",
      "description": "Group all Helm charts in kube-system namespace",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["**/kube-system/**"],
      "matchUpdateTypes": ["minor", "patch"],
      "automergeType": "pr",
      "automerge": false
    },

    {
      "groupName": "helm/strooware-system",
      "description": "Group all Helm charts in strooware-system namespace",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["**/strooware-system/**"],
      "matchUpdateTypes": ["minor", "patch"],
      "automergeType": "pr",
      "automerge": false
    },

    {
      "groupName": "packages/maplibre",
      "description": "Group all maplibre packages into a single PR",
      "matchPackageNames": ["map*-gl"]
    },
    {
      "groupName": "packages/solidjs",
      "description": "Group all solid packages into a single PR",
      "matchPackageNames": ["@solid-**", "@solidjs/**", "solid-**"]
    },
    {
      "groupName": "packages/tanstack",
      "description": "Group all tanstack packages into a single PR",
      "matchPackageNames": ["@tanstack/**"]
    },
    {
      "groupName": "packages/unocss",
      "description": "Group all unocss packages into a single PR",
      "matchPackageNames": ["@iconify-json/**", "@unocss/**", "unocss**"],
      "automergeType": "pr",
      "automerge": true
    }
  ],

  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [".*y[a]?ml$"],
      "datasourceTemplate": "helm",
      "matchStrings": [
        "kind:\\s*HelmChart\\n[\\s\\w:-]*chart:\\s+(?<depName>.+)\\n[\\s\\w:-]*\\s+(?<currentValue>v?[0-9.]+)\\n[\\s\\w:-]*\\s+(?<registryUrl>https://.+)\\n"
      ]
    }
  ]
}
